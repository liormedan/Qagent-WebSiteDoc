# Copy this file to `.env.local` and fill values.
# Do not commit real secrets.

# -----------------------------
# Clerk (required for auth)
# -----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ADMIN_EMAIL=liormedan1@gmail.com
CLERK_WEBHOOK_SIGNING_SECRET=

# Optional Clerk URLs (recommended for production consistency)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/docs
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/docs

# Optional app URL used in approval emails
APP_BASE_URL=https://qagent-web-site-doc.vercel.app
ADMIN_APPROVAL_EMAIL=liormedan1@gmail.com

# -----------------------------
# Ask Q (Gemini) - server only
# -----------------------------
GEMINI_API_KEY=

# Email provider for notifications (Resend)
RESEND_API_KEY=
EMAIL_FROM=no-reply@yourdomain.com

# Optional overrides
# GEMINI_MODEL=gemini-3.1-pro-preview
# ASK_Q_GEMINI_DAILY_MAX=100
