# דוגמה בלבד: העתק ל־`.env.local` לפיתוח; אל תעלה מפתחות אמיתיים ל־git.
# Copy to `.env.local` for local Next — never commit real keys.
# Connectivity: `npm run test:gemini` (loads .env.local automatically).
#
# --- Ask Q (Gemini) — server only (`/api/ask-q`) ---
# Without GEMINI_API_KEY, Ask Q returns retrieval-only answers (no external AI).

GEMINI_API_KEY=

# Default in code: gemini-3-flash-preview (Gemini 3). Override if needed.
# GEMINI_MODEL=gemini-3.1-pro-preview

# Max Ask Q requests per day that use Gemini (UTC day). When reached, API returns Hebrew notice + retrieval-only text.
# ASK_Q_GEMINI_DAILY_MAX=100
